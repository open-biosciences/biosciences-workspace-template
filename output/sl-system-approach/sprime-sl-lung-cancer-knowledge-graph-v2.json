  "network_fragility_analysis": {
    "description": "The S′/ΔS′ framework identifies systemic SL as distributed network fragility rather than classical pairwise gene interactions. The BioGRID interaction counts quantify each tumor suppressor's hub degree, providing a proxy for how many network connections are disrupted by its loss.",
    "hub_degree_by_biogrid": {
      "TP53": {"biogrid_interactions": 6075, "interpretation": "Highest hub degree. TP53 loss disrupts the largest number of regulatory connections, explaining the deep spindle-checkpoint SL phenotype (KIF11 inhibitors)."},
      "PTEN": {"biogrid_interactions": 1193, "interpretation": "Second highest. PTEN loss derepresses AKT-PI3K-mTOR signaling; the multi-axis SL signature reflects disrupted control of a major survival pathway."},
      "RB1": {"biogrid_interactions": 1150, "interpretation": "Third highest. RB1 loss deregulates E2F-driven proliferation, creating multi-axis dependencies across mitotic checkpoint, PI3K/AKT, DNA repair, and epigenetic axes."},
      "CDKN2A": {"biogrid_interactions": 649, "interpretation": "Lowest hub degree. CDKN2A loss has a more focused impact through CDK4/6 derepression, consistent with its coordinated but narrower SL profile."}
    },
